{# #### Sablona hlavicky pro vsechny stranky #### #}

{# pripojuju makra #}
{% import "macro.twig" as macro %}

{# HTML #}
<div class="container">
    <h1 class="mb-3">{{contribution['contributions_name'] | escape}}</h1>
    <p class="lead">
        <i class="fa fa-user"></i>
        <span class="text-decoration-none ms-1 text-dark">{{contribution['users_name'] | escape}} {{ contribution['users_surname'] | escape}}</span>
    </p>
    <p>
        <i class="fa fa-calendar me-2"></i>
        <b>Datum:</b> {{contribution['contributions_created'] |escape}}
    </p>

    <hr>
    <h3>Abstrakt</h3>
    <p class="lead">{{contribution['contributions_abstract'] |escape}}</p>
    <div class="mt-4">
        <h3>Soubory s příspěvkem</h3>

        {{ macro.contribution_files_div(file, 0) }}
