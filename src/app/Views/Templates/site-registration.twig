{# #### Sablona pro Twig v.2 - vypis uvodni stranky #### #}

{# dedim od zakladni sablony #}
{% extends "template-basic.twig" %}

{# prekryvam cely blok obsahu #}
{% block obsah %}

    <div class="container">

        <form action="#" method="post" accept-charset="UTF-8" autocomplete="on">
            <fieldset class="mb-3">
                <h3>Osobní údaje</h3>


                <div class="mb-3">
                    <label class="form-label" for="user_name">Křestní jméno</label>
                    <input class="form-control" type="text" name="user_name" id="user_name" required>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="user_surname">Příjmeni</label>
                    <input class="form-control" type="text" name="user_surname" id="user_surname" required>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="user_email">Email</label>
                    <input class="form-control" type="email" name="user_email" id="user_email" required>
                </div>
            </fieldset>

            <fieldset>
                <h3>Přihlašovací údaje</h3>


                <div class="mb-3">
                    <label class="form-label" for="user_username">Přihlašovací jméno</label>
                    <input class="form-control" type="text" name="user_username" id="user_username" required>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="user_password">Heslo</label>
                    <input class="form-control" type="password" name="user_password" id="user_password" required>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="user_passwordcheck">Heslo podruhé</label>
                    <input class="form-control" type="password" name="user_passwordcheck" id="user_passwordcheck" required>
                </div>
            </fieldset>


            <button type="submit" name="action" value="registration" id="contribution_submit" class="btn btn-lg btn-primary mt-3">Registrovat</button>


        </form>
    </div>

{% endblock %}